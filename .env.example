# Copy to .env and fill in from your Supabase project's Settings > API page.
# Safe to expose client-side: access is gated by the RLS policies in
# supabase/schema.sql, not by keeping this secret. EXPO_PUBLIC_* is inlined into
# the app bundle by Expo, so only put things here that are safe to ship.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# The `service_role` secret from that same page. NOT safe to expose: it bypasses
# RLS entirely. Deliberately not EXPO_PUBLIC_, so it never reaches the bundle -
# nothing under src/ may read it. Used only by scripts/upload-catalog-images.mjs,
# which publishes the app's catalog artwork; the policies in supabase/schema.sql
# forbid every client from writing or deleting that artwork, so this key is the
# only way to change it. Leave blank unless you're publishing images.
SUPABASE_SERVICE_ROLE_KEY=
